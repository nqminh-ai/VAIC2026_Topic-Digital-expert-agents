# =============================================================================
# VAIC2026 — Shared Environment Configuration
# Copy this file to .env and fill in the required values.
# This single file is read by both backend (Node.js) and frontend (Vite).
# =============================================================================

# ---------------------------------------------------------------------------
# Backend / Express
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# PostgreSQL (Docker internal host: 'postgres' | local: 'localhost')
# ---------------------------------------------------------------------------
PG_HOST=postgres
PG_PORT=5432
PG_USER=vaic
PG_PASSWORD=change_me_pg_password
PG_DB=vaic_db

# ---------------------------------------------------------------------------
# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
# Connection Pooler URL (Transaction Mode, port 5432) from Supabase Dashboard
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Redis (Docker internal host: 'redis' | local: 'localhost')
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Neo4j (Docker internal host: 'neo4j' | local: 'localhost')
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# ---------------------------------------------------------------------------
# Auth — JWT signing secret
# Generate with: openssl rand -hex 32
# REQUIRED — server refuses to start without this.
# ---------------------------------------------------------------------------
AUTH_JWT_SECRET=change_me_to_a_long_random_secret

# Demo identity passwords (services/auth/demo-user.store.ts)
# Replace with real SSO/AD integration before production.
DEMO_OFFICER_PASSWORD=change_me_officer_password
DEMO_APPROVER_PASSWORD=change_me_approver_password

# ---------------------------------------------------------------------------
# FPT AI Marketplace (OpenAI-compatible)
# Used by Legal Agent, Planner, and Extraction agents.
# ---------------------------------------------------------------------------
FPT_MARKETPLACE_API_KEY=your_fpt_marketplace_api_key
FPT_MARKETPLACE_BASE_URL=https://mkp-api.fptcloud.com
FPT_LEGAL_MODEL=GLM-5.2
FPT_PLANNER_MODEL=GLM-5.2
FPT_EXTRACTION_MODEL=GLM-5.2

# ---------------------------------------------------------------------------
# OCR (Tesseract — bundled in Docker, Vietnamese + English)
# ---------------------------------------------------------------------------
OCR_LANGUAGES=vie+eng
OCR_PDF_DPI=200
OCR_MAX_PDF_PAGES=10
# Only set these when running outside Docker and binaries are not on PATH.
# TESSERACT_COMMAND=tesseract
# PDFTOPPM_COMMAND=pdftoppm

# ---------------------------------------------------------------------------
# Optional: private fine-tuned model endpoint (takes precedence over FPT)
# ---------------------------------------------------------------------------
# LEGAL_LLM_API_KEY=
# LEGAL_LLM_BASE_URL=
# LEGAL_LLM_MODEL=

# ---------------------------------------------------------------------------
# Frontend (Vite) — must be prefixed with VITE_ to be exposed to the browser
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000
